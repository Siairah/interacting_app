# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ----------------------
# Dependencies
# ----------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----------------------
# Testing
# ----------------------
/coverage

# ----------------------
# Next.js
# ----------------------
/.next/
/out/

# ----------------------
# Production
# ----------------------
/build

# ----------------------
# Misc
# ----------------------
.DS_Store
*.pem

# ----------------------
# Local / Tooling (do not commit)
# Ignore PTH folder anywhere in repo
**/PTH/

# ----------------------
# Backend (separate repo)
# Ignore backend learn folder anywhere in repo
**/backend learn/

# ----------------------
# Debug logs
# ----------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----------------------
# Env files
# ----------------------
.env*
!.env.example

# ----------------------
# Vercel
# ----------------------
.vercel

# ----------------------
# TypeScript
# ----------------------
*.tsbuildinfo
next-env.d.ts
*.md
deploy/*